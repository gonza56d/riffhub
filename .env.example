# Copy to `.env` for local development. Docker Compose also reads this file.
#
# riffhub runs from ONE settings module, switched by DJANGO_ENV (dev | prod).
# Variables already present in the real environment (e.g. injected by Docker
# Compose) take precedence over this file. Full production walkthrough:
# deploy/PYTHONANYWHERE.md

# =============================================================================
# Environment switch
# =============================================================================
# "dev" (default): DEBUG on, relaxed security.
# "prod": DEBUG off, HTTPS/cookie/HSTS hardening, and SECRET_KEY + ALLOWED_HOSTS
#         + DATABASE_URL are REQUIRED (the app refuses to start without them).
DJANGO_ENV=dev

# Optional explicit override of DEBUG (defaults: True in dev, False in prod).
# DEBUG=True

# =============================================================================
# Local development (Docker Compose) — works out of the box
# =============================================================================
SECRET_KEY=django-insecure-dev-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Postgres credentials (consumed by the docker-compose "db" service).
POSTGRES_DB=riffhub
POSTGRES_USER=riffhub
POSTGRES_PASSWORD=riffhub

# Django database connection.
# Under Docker Compose the host is the "db" service name:
DATABASE_URL=postgres://riffhub:riffhub@db:5432/riffhub
# To run manage.py from the local venv instead (db port is published), use:
# DATABASE_URL=postgres://riffhub:riffhub@localhost:5432/riffhub

# How often (in seconds) the opt-in "scheduler" service runs
# `manage.py evaluate_pending` to sweep due proposals and pending submissions.
# Default is hourly. Opt-in via the "scheduler" compose profile:
# `docker compose --profile scheduler up`.
EVAL_INTERVAL_SECONDS=3600

# =============================================================================
# Production (Render) — set DJANGO_ENV=prod
# =============================================================================
# On Render you DON'T create a .env file: these are set in render.yaml / the
# dashboard (DATABASE_URL is injected from the managed DB, SECRET_KEY is
# generated, ALLOWED_HOSTS is in render.yaml). Full guide: deploy/RENDER.md.
# This section is a reference for the prod knobs (also useful on other hosts).
#
# DJANGO_ENV=prod
#
# Generate a fresh secret (on Render this is done for you via generateValue):
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
# SECRET_KEY=replace-with-a-50+char-random-secret
#
# Your site host(s), comma-separated, NO scheme:
# ALLOWED_HOSTS=riffhub.onrender.com
#
# CSRF trusted origins MUST include the scheme (needed for a custom domain; the
# *.onrender.com host is trusted automatically via RENDER_EXTERNAL_HOSTNAME):
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
#
# Postgres connection (on Render this is injected automatically):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
# --- Optional prod tuning (defaults shown) -----------------------------------
# CONN_MAX_AGE=60                  # persistent DB connections, seconds
# SECURE_SSL_REDIRECT=False        # keep False on Render (its edge forces HTTPS); True on hosts that don't
# LOG_LEVEL=WARNING
# HSTS: enable once HTTPS is permanent for your (ideally custom) domain.
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False
#
# --- Outbound e-mail (dev/default uses the console backend) -------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey-or-username
# EMAIL_HOST_PASSWORD=secret
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=riffhub <no-reply@yourdomain.com>
